# Copy to backend/.env and adjust.
#
# POC defaults target a localhost Postgres with the default admin user and are
# fine for LOCAL development only (ENV=dev). For any shared/hosted deployment set
# ENV=prod: the app then refuses to start on the default superuser/password or a
# non-TLS connection. See docs/pii-hardening-plan.md §H1.

# Deployment environment. dev/development/local/test/ci => POC mode (no guard).
# Anything else (e.g. prod) enforces the security checks below.
ENV=dev

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=courtops
PGADMIN_DB=postgres

# libpq TLS mode: prefer (default, dev), or require / verify-ca / verify-full.
# ENV=prod requires one of require/verify-ca/verify-full.
PGSSLMODE=prefer

# PII at rest (H2): Fernet key used to encrypt the inbound email body. A POC dev
# default is used when unset; ENV=prod requires a real key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PII_ENCRYPTION_KEY=
# Optional rotation list (newest first): PII_ENCRYPTION_KEYS=NEW,OLD

# Session lifetime (audit D3). 1–90 days. Unset → 30 in dev, 7 when ENV=prod.
# COURTOPS_SESSION_DAYS=7
# Force password-change API gate even in dev (or disable in prod):
# COURTOPS_FORCE_PASSWORD_CHANGE=1
# COURTOPS_FORCE_PASSWORD_CHANGE=0
# Real deploys: set ADMIN_PASSWORD so seed/entrypoint never leaves admin/admin.

# Security headers (audit D17). On by default for API + static responses.
# COURTOPS_SECURITY_HEADERS=0   # disable entirely (debug only)
# COURTOPS_CSP=...              # override full Content-Security-Policy string
# COURTOPS_HSTS=1               # force Strict-Transport-Security (also auto in ENV=prod)
# COURTOPS_HSTS=0               # never send HSTS even in prod

# COPPA / under-13 (audit D16). Writes that set a birthdate implying age < 13:
#   unset + ENV=dev  → allowed (POC seed/tests)
#   unset + ENV=prod → blocked (403) until you opt in
#   1 / true         → allowed (accept residual plaintext names/USTA #)
#   0 / false        → blocked even in dev
# See docs/coppa-policy.md. Machine-readable: GET /api/coppa/policy
# ALLOW_UNDER13_PII=

# Email auto-ingest (D4): shared secret for POST /api/ingest/email.
# Empty / unset = ingest disabled (503). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# INGEST_TOKEN=
# Optional: land mail that has no matching tournament.ingest_address here.
# INGEST_DEFAULT_TOURNAMENT_ID=
